<component type="desktop-application">
  <id>com.automattic.beeper</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>LicenseRef-proprietary</project_license>

  <name>Beeper (Unofficial)</name>
  <summary>All your chats in one app</summary>

  <developer id="com.automattic">
    <name>Automattic, Inc.</name>
  </developer>

  <url type="homepage">https://www.beeper.com</url>
  <url type="help">https://support.beeper.com</url>

  <description>
    <p>
      <em>NOTE: This wrapper is not verified by, affiliated with, or supported by Automattic, Inc.</em>
    </p>
    <p>
      Beeper is a universal messaging app that brings together your chats from
      WhatsApp, Telegram, Signal, Instagram, Facebook Messenger,
      Twitter/X DMs, LinkedIn, Slack, Discord, and more — all in one place,
      powered by the Matrix protocol.
    </p>
    <p>
      Features include:
    </p>
    <ul>
      <li>Unified inbox across all your chat networks</li>
      <li>End-to-end encrypted bridges via Matrix</li>
      <li>Cross-platform sync: desktop, web, and mobile</li>
      <li>Keyboard shortcuts and productivity features</li>
      <li>System tray support and native notifications</li>
    </ul>
  </description>

  <launchable type="desktop-id">com.automattic.beeper.desktop</launchable>

  <provides>
    <binary>beeper</binary>
  </provides>

  <content_rating type="oars-1.1">
    <content_attribute id="social-chat">intense</content_attribute>
    <content_attribute id="social-audio">moderate</content_attribute>
    <content_attribute id="social-contacts">intense</content_attribute>
  </content_rating>

  <screenshots>
    <screenshot type="default">
      <image>https://raw.githubusercontent.com/Zylquinal/beeper-flatpak/master/assets/screenshot-1.png</image>
    </screenshot>
  </screenshots>

  <releases>
    <release version="4.2.808" date="2026-05-06">
      <description>
        <p>Beeper stable release 4.2.808.</p>
      </description>
    </release>
  </releases>
</component>
